---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Pricing from '../components/Pricing.astro';
import Process from '../components/Process.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
---

<Layout lang="es" title={undefined}>
	<Header lang="es" />
	<main>
		<Hero lang="es" />
		<Features lang="es" />
		<Pricing lang="es" />
		<Process lang="es" />
		<FAQ lang="es" />
	</main>
	<Footer lang="es" />
	<ContactModal lang="es" />
</Layout>

<script>
	const supported = ['es', 'en', 'pt'];
	const stored = localStorage.getItem('zynera-lang');
	const nav = (navigator.language ?? navigator.languages?.[0] ?? 'es').slice(0, 2);
	const detected = stored ?? nav;
	const lang = supported.includes(detected) ? detected : 'es';
	localStorage.setItem('zynera-lang', lang);
	if (!window.location.pathname.includes(`/${lang}/`)) {
		window.location.replace(`${import.meta.env.BASE_URL}${lang}/`);
	}
</script>
