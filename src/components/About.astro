---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }

const { lang } = Astro.props;
const dict = t(lang);
---
<section id="nosotros" class="section-padding reveal">
    <div class="container" style="max-width: 700px; text-align: center;">
        <div class="section-header">
            <h2>{dict.about.heading}</h2>
        </div>
        <p class="about-text">{dict.about.text}</p>
    </div>
</section>

<style>
    .about-text {
        color: var(--text-dim);
        font-size: 1.05rem;
        line-height: 1.7;
        max-width: 600px;
        margin: 0 auto;
    }
</style>
