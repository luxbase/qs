---
const baseUrl = import.meta.env.BASE_URL;
const beforeImageSrc = `${baseUrl}images/antes.png`;
const afterImageSrc = `${baseUrl}images/despues.png`;
---
<section id="resultados" class="section-padding reveal">
    <div class="container">
        <div class="section-header">
            <h2>Visualizá el impacto</h2>
            <p>Deslizá para ver cómo transformamos un espacio vacío en un anuncio de lujo.</p>
        </div>
        
        <div class="slider-container" id="beforeAfter">
            <div class="slider-img img-before">
                <img src={beforeImageSrc} alt="Habitación vacía antes del staging digital" loading="lazy" decoding="async" />
                <span class="label label-before">ANTES</span>
            </div>
            <div class="slider-img img-after" id="afterImg">
                <img src={afterImageSrc} alt="Habitación decorada después del staging digital de Zynera" loading="lazy" decoding="async" />
                <span class="label label-after">DESPUÉS</span>
            </div>
            <div class="slider-handle" id="sliderHandle">
                <div class="handle-circle"></div>
            </div>
            <input type="range" min="0" max="100" value="50" class="slider-input" id="sliderInput" aria-label="Comparar antes y después">
        </div>

        <div class="metrics">
            <div class="metrics-grid">
                <div class="metric-item">
                    <h4>3x</h4>
                    <p>Más consultas</p>
                </div>
                <div class="metric-item">
                    <h4>48h</h4>
                    <p>Entrega promedio</p>
                </div>
                <div class="metric-item">
                    <h4>800+</h4>
                    <p>Agentes en Paraguay</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .slider-container {
        position: relative;
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
        aspect-ratio: 16/10;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        cursor: ew-resize;
    }

    .slider-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-style: italic;
        background: #171717;
    }

    .slider-img img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .label {
        position: absolute;
        top: 20px;
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    .label-before {
        left: 20px;
        opacity: 0.5;
    }

    .label-after {
        right: 20px;
    }

    .img-before {
        color: transparent;
        z-index: 1;
    }

    .img-after {
        color: transparent;
        z-index: 2;
        clip-path: inset(0 0 0 50%);
    }

    .slider-handle {
        position: absolute;
        top: 0;
        left: 50%;
        width: 2px;
        height: 100%;
        background: var(--accent-color);
        z-index: 3;
        transform: translateX(-50%);
        pointer-events: none;
    }

    .handle-circle {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 40px;
        height: 40px;
        background: var(--accent-color);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px rgba(232, 194, 122, 0.4);
    }

    .handle-circle::before, .handle-circle::after {
        content: "";
        border: solid var(--bg-color);
        border-width: 0 3px 3px 0;
        display: inline-block;
        padding: 4px;
    }

    .handle-circle::before { transform: rotate(135deg); margin-right: -4px; }
    .handle-circle::after { transform: rotate(-45deg); margin-left: -4px; }

    .slider-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        z-index: 4;
        cursor: ew-resize;
    }

    .metrics {
        background: var(--card-bg);
        padding: 80px 0;
        margin-top: 60px;
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 40px;
        text-align: center;
    }

    .metric-item h4 {
        font-size: 3.5rem;
        color: var(--accent-color);
        margin-bottom: 8px;
    }

    .metric-item p {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
        color: var(--text-dim);
    }
</style>

<script>
    const sliderInput = document.getElementById('sliderInput') as HTMLInputElement;
    const afterImg = document.getElementById('afterImg');
    const sliderHandle = document.getElementById('sliderHandle');

    sliderInput?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const value = target.value;
        if (afterImg) afterImg.style.clipPath = `inset(0 0 0 ${value}%)`;
        if (sliderHandle) sliderHandle.style.left = `${value}%`;
    });
</script>
