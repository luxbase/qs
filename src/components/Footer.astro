---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }

const { lang } = Astro.props;
const dict = t(lang);
const baseUrl = import.meta.env.BASE_URL;
const langPrefix = `${baseUrl}${lang}/`;
---
<footer>
    <div class="container">
        <div class="footer-main">
            <div class="footer-brand">
                <a href={langPrefix} class="footer-logo">
                    <svg class="footer-mark" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 30V10H30" stroke="#e8c27a" stroke-width="4" stroke-linecap="square"/>
                        <path d="M30 15H15V30" stroke="#e8c27a" stroke-width="2.5" stroke-linecap="square"/>
                        <path d="M20 25V20H25" stroke="#e8c27a" stroke-width="1.5" stroke-linecap="square"/>
                    </svg>
                    Zynera
                </a>
                <p class="footer-tag">{dict.footer.tagline}</p>
            </div>
            <nav class="footer-nav">
                <a href={`${langPrefix}#resultados`}>{dict.footer.resultados}</a>
                <a href={`${langPrefix}#faq`}>{dict.footer.faq}</a>
                <a href={dict.header.whatsappUrl} target="_blank" rel="noopener">{dict.footer.whatsapp}</a>
                <a href={`${baseUrl}privacidad/`}>{dict.footer.privacidad}</a>
            </nav>
        </div>
        <div class="footer-bottom">
            <p>&copy; {new Date().getFullYear()} {dict.footer.copyright}</p>
        </div>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding: 64px 0 40px;
    }

    .footer-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 32px;
    }

    .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--accent-color);
        text-decoration: none;
        letter-spacing: 2px;
    }

    .footer-mark {
        width: 24px;
        height: 24px;
    }

    .footer-tag {
        color: var(--text-dim);
        font-size: 0.8rem;
    }

    .footer-nav {
        display: flex;
        gap: 32px;
        flex-wrap: wrap;
    }

    .footer-nav a {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
    }

    .footer-nav a:hover {
        color: var(--accent-color);
    }

    .footer-bottom {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        text-align: center;
        color: var(--text-dim);
        font-size: 0.8rem;
    }
</style>
