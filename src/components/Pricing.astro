---
import { t, type Lang } from '../i18n';

interface Props { lang: Lang }

const { lang } = Astro.props;
const dict = t(lang);
---
<section id="servicios" class="section-padding reveal">
    <div class="container">
        <div class="section-header">
            <h2>{dict.pricing.heading}</h2>
            <p>{dict.pricing.p}</p>
        </div>
        <div class="services-grid">
            {dict.pricing.cards.map((card, i) => (
                <div class={`pricing-card${card.popular ? ' popular' : ''}`}>
                    {card.popular && <span class="badge">{dict.pricing.popularBadge}</span>}
                    <span class="tier-name">{card.name}</span>
                    <div class="tier-price">{card.price} <span>{card.per}</span></div>
                    {card.subtitle && <p class="tier-subtitle">{card.subtitle}</p>}
                    <ul class="tier-features">
                        {card.features.map(f => <li>{f}</li>)}
                    </ul>
                </div>
            ))}
        </div>
        <div class="pricing-cta">
            <button class="btn-pricing-cta" id="pricingCtaBtn" type="button">{dict.pricing.pricingCta}</button>
        </div>
        <p class="payment-note">{dict.pricing.paymentNote}</p>
        <div class="cold-start">
            <p class="cold-start-title">{dict.pricing.coldStart.title}</p>
            <p class="cold-start-desc">{dict.pricing.coldStart.desc} <a href={dict.pricing.coldStart.waUrl} target="_blank" rel="noopener">{dict.pricing.coldStart.cta}</a></p>
            <p class="cold-start-referral">{dict.pricing.coldStart.referral}</p>
        </div>
    </div>
</section>

<style>
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        max-width: 1060px;
        margin: 0 auto;
    }

    .pricing-card {
        background: var(--card-bg);
        padding: 32px;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

    .pricing-card.popular {
        border-color: var(--accent-color);
    }

    .badge {
        position: absolute;
        top: 30px;
        right: -45px;
        background: var(--accent-color);
        color: var(--bg-color);
        font-size: 0.7rem;
        font-weight: 800;
        padding: 6px 40px;
        line-height: 1;
        transform: rotate(45deg);
    }

    .tier-name {
        font-size: 0.9rem;
        letter-spacing: 2px;
        color: var(--accent-color);
        margin-bottom: 10px;
        font-weight: 700;
    }

    .tier-price {
        font-size: 2.5rem;
        margin-bottom: 4px;
        font-family: 'Playfair Display', serif;
    }

    .tier-price span {
        font-size: 1rem;
        color: var(--text-dim);
        font-family: 'DM Sans', sans-serif;
    }

    .tier-subtitle {
        font-size: 0.8rem;
        color: var(--text-dim);
        margin-bottom: 16px;
    }

    .tier-features {
        list-style: none;
        flex-grow: 1;
        margin-bottom: 20px;
    }

    .tier-features li {
        margin-bottom: 8px;
        color: var(--text-dim);
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .tier-features li::before {
        content: "✓";
        color: var(--accent-color);
        font-weight: bold;
    }

    .pricing-cta {
        text-align: center;
        margin-top: 32px;
    }

    .btn-pricing-cta {
        background-color: var(--accent-color);
        color: var(--bg-color);
        border: none;
        padding: 16px 40px;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
        font-family: 'DM Sans', sans-serif;
    }

    .btn-pricing-cta:hover {
        opacity: 0.9;
    }

    .payment-note {
        text-align: center;
        color: var(--text-dim);
        font-size: 0.85rem;
        margin-top: 32px;
    }

    .cold-start {
        text-align: center;
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid rgba(255,255,255,0.06);
        max-width: 1060px;
        margin-left: auto;
        margin-right: auto;
    }

    .cold-start-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        color: var(--accent-color);
        margin-bottom: 12px;
    }

    .cold-start-desc {
        color: var(--text-dim);
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .cold-start-desc a {
        color: var(--accent-color);
        font-weight: 700;
        text-decoration: none;
    }

    .cold-start-desc a:hover {
        text-decoration: underline;
    }

    .cold-start-referral {
        color: var(--text-dim);
        font-size: 0.85rem;
        opacity: 0.8;
    }
</style>

<script>
    document.getElementById('pricingCtaBtn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-modal'));
    });
</script>
