---
<section id="faq" class="section-padding reveal">
    <div class="container" style="max-width: 800px;">
        <div class="section-header">
            <h2>Preguntas Frecuentes</h2>
        </div>
        <div class="faq-item">
            <button type="button" class="faq-question" aria-expanded="false" aria-controls="faq-answer-1">
                ¿Tengo que mover muebles o decorar la propiedad? <span class="faq-toggle">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-1" hidden>
                No es necesario. Nosotros capturamos el espacio tal cual está y luego realizamos la decoración virtual sobre la imagen real en post-producción.
            </div>
        </div>
        <div class="faq-item">
            <button type="button" class="faq-question" aria-expanded="false" aria-controls="faq-answer-2">
                ¿En cuánto tiempo recibo el material final? <span class="faq-toggle">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-2" hidden>
                Nuestro compromiso de entrega es de 48 horas hábiles después de realizada la sesión de fotos en la propiedad.
            </div>
        </div>
        <div class="faq-item">
            <button type="button" class="faq-question" aria-expanded="false" aria-controls="faq-answer-3">
                ¿Llegan a todo el país? <span class="faq-toggle">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-3" hidden>
                Actualmente cubrimos Gran Asunción, proximamente Ciudad del Este y Encarnación. Consultanos por disponibilidad y viáticos para otras zonas de Paraguay.
            </div>
        </div>
        <div class="faq-item">
            <button type="button" class="faq-question" aria-expanded="false" aria-controls="faq-answer-4">
                ¿Qué estilos de decoración utilizan? <span class="faq-toggle">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-4" hidden>
                Contamos con catálogos modernos, industriales y clásicos. Seleccionamos el estilo que mejor se adapte al perfil del comprador ideal para esa zona.
            </div>
        </div>
        <div class="faq-item">
            <button type="button" class="faq-question" aria-expanded="false" aria-controls="faq-answer-5">
                ¿Las fotos sirven para portales y redes sociales? <span class="faq-toggle">▼</span>
            </button>
            <div class="faq-answer" id="faq-answer-5" hidden>
                Sí. Todo el material se entrega en alta resolución para portales y optimizado para Instagram, TikTok y Facebook.
            </div>
        </div>
        
        <div style="text-align: center; margin-top: 60px;">
            <button class="btn-wizard" id="faqWizardBtn" type="button">Mejorar mi publicación →</button>
        </div>
    </div>
</section>

<style>
    .faq-item {
        background: var(--card-bg);
        border-radius: 12px;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .faq-question {
        padding: 24px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        width: 100%;
        background: transparent;
        border: 0;
        color: var(--text-main);
        font: inherit;
        text-align: left;
    }

    .faq-answer {
        padding: 0 24px 24px;
        color: var(--text-dim);
    }

    .faq-toggle {
        transition: transform 0.3s ease;
    }

    .faq-item.active .faq-toggle {
        transform: rotate(180deg);
    }

    .btn-wizard {
        background-color: var(--accent-color);
        color: var(--bg-color);
        border: none;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
    }

    .btn-wizard:hover {
        opacity: 0.9;
    }
</style>

<script>
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        question?.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            faqItems.forEach(i => {
                i.classList.remove('active');
                i.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
                const answer = i.querySelector('.faq-answer') as HTMLElement | null;
                if (answer) answer.hidden = true;
            });
            if (!isActive) {
                item.classList.add('active');
                question.setAttribute('aria-expanded', 'true');
                const answer = item.querySelector('.faq-answer') as HTMLElement | null;
                if (answer) answer.hidden = false;
            }
        });
    });

    document.getElementById('faqWizardBtn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-modal'));
    });
</script>
