---
import { t, type Lang } from '../i18n';
import { WHATSAPP_NUMBER } from '../constants';

interface Props { lang: Lang }

const { lang } = Astro.props;
const dict = t(lang);
const SUBMITKIT_URL = "https://submitkit.dev/api/f/cmqe12stc0006sp211lp2fa2e";
const WHATSAPP_BASE = `https://wa.me/${WHATSAPP_NUMBER}`;
const s = dict.modal.steps;
---

<div class="modal" id="qualisModal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-content">
        <div class="modal-header">
            <span class="modal-title">{dict.modal.title}</span>
            <button class="modal-close" id="closeModal" type="button" aria-label={dict.modal.closeLabel}>&times;</button>
        </div>

        <p class="modal-desc">{dict.modal.description}</p>

        <div class="step-indicator" id="stepIndicator">
            <div class="step-dot active" data-step="1" aria-label={dict.modal.stepIndicator.replace('{n}', '1')} role="progressbar" aria-valuenow="1" aria-valuemin="1" aria-valuemax="4">1</div>
            <div class="step-line" aria-hidden="true"></div>
            <div class="step-dot" data-step="2" aria-label={dict.modal.stepIndicator.replace('{n}', '2')} role="progressbar" aria-valuenow="2" aria-valuemin="1" aria-valuemax="4">2</div>
            <div class="step-line" aria-hidden="true"></div>
            <div class="step-dot" data-step="3" aria-label={dict.modal.stepIndicator.replace('{n}', '3')} role="progressbar" aria-valuenow="3" aria-valuemin="1" aria-valuemax="4">3</div>
            <div class="step-line" aria-hidden="true"></div>
            <div class="step-dot" data-step="4" aria-label={dict.modal.stepIndicator.replace('{n}', '4')} role="progressbar" aria-valuenow="4" aria-valuemin="1" aria-valuemax="4">4</div>
        </div>

        <form id="wizardForm" class="wizard-form" novalidate>
            <input type="hidden" name="_nota" value="Las fotos enviadas están disponibles en https://submitkit.dev/forms">
            <div class="step-content">
                <div class="step-panel active" data-step="1">
                    <label class="step-label" for="name">{s[0].nameLabel}</label>
                    <input type="text" id="name" class="input" name="Nombre" placeholder={s[0].namePlaceholder} required autocomplete="name">
                    <span class="error-msg" id="nameError"></span>

                    <label class="step-label" style="margin-top: 20px;" id="modeLabel">{s[0].modeLabel}</label>
                    <div class="mode-options" role="radiogroup" aria-labelledby="modeLabel">
                        {s[0].modes.map(m => (
                            <label class="mode-option">
                                <input type="radio" name="Modo" value={m.value} checked={m.value === 'Handoff' ? true : undefined}>
                                <span class="mode-label">{m.label}<small>{m.desc}</small></span>
                            </label>
                        ))}
                    </div>
                    <span class="error-msg" id="modeError"></span>
                </div>

                <div class="step-panel" data-step="2">
                    <label class="step-label" for="email">{s[1].emailLabel}</label>
                    <input type="email" id="email" class="input" name="Email" placeholder={s[1].emailPlaceholder} required autocomplete="email">
                    <span class="error-msg" id="emailError"></span>

                    <label class="step-label" for="phone" style="margin-top: 20px;">{s[1].phoneLabel}</label>
                    <input type="tel" id="phone" class="input" name="Telefono" placeholder={s[1].phonePlaceholder} autocomplete="tel">
                    <span class="error-msg" id="phoneError"></span>
                </div>

                <div class="step-panel" data-step="3">
                    <label class="step-label">{s[2].photoLabel}</label>
                    <div class="file-upload" id="fileDropZone" role="button" tabindex="0">
                        <input type="file" id="photo" name="Foto" accept="image/png,image/jpeg" required hidden>
                        <div class="file-placeholder" id="filePlaceholder">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#a0a0a0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m17 8-5-5-5 5"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/></svg>
                            <span>{s[2].dropText}</span>
                            <small>{s[2].dropFormat}</small>
                        </div>
                        <div class="file-preview" id="filePreview" style="display:none">
                            <img id="previewImg" alt="Preview">
                            <button type="button" class="file-remove" id="fileRemove">&times;</button>
                        </div>
                    </div>
                    <span class="error-msg" id="photoError"></span>
                </div>

                <div class="step-panel" data-step="4">
                    <label class="step-label" id="styleLabel">{s[3].styleLabel}</label>
                    <div class="style-options" role="radiogroup" aria-labelledby="styleLabel">
                        {s[3].styles.map(st => (
                            <label class="style-option">
                                <input type="radio" name="Estilo" value={st} required>
                                <span>{st}</span>
                            </label>
                        ))}
                    </div>
                    <span class="error-msg" id="styleError"></span>
                    <label class="consent-label">
                        <input type="checkbox" name="Consentimiento" value="Acepto" required>
                        <span>{s[3].privacyConsent} <a href={`${import.meta.env.BASE_URL}privacidad`} target="_blank" rel="noopener">({s[3].privacyLink})</a></span>
                    </label>
                </div>
            </div>

            <div class="step-nav">
                <button type="button" class="btn-back" id="btnBack" style="visibility:hidden">{dict.modal.back}</button>
                <button type="button" class="btn-next" id="btnNext">{dict.modal.next}</button>
                <button type="submit" class="btn-submit" id="btnSubmit" style="display:none">{dict.modal.submit}</button>
            </div>
        </form>

        <div id="loadingContainer" style="display:none">
            <div class="spinner"></div>
            <p>{dict.modal.loading}</p>
        </div>

        <div id="successContainer" style="display:none">
            <div class="success-icon">&#10003;</div>
            <h2>{dict.modal.success.title}</h2>
            <p>{dict.modal.success.text}</p>
            <a class="btn-success-wa" id="successWaLink" href="#" target="_blank" rel="noopener">{dict.modal.success.waCta}</a>
            <button class="btn-new" id="btnNew" type="button">{dict.modal.success.newRequest}</button>
        </div>

        <div id="errorContainer" style="display:none">
            <div class="error-icon">!</div>
            <h2>{dict.modal.error.title}</h2>
            <p id="errorMsg">{dict.modal.error.text}</p>
            <button class="btn-retry" id="btnRetry" type="button">{dict.modal.error.retry}</button>
        </div>
    </div>
    <iframe name="submit-frame" id="submitFrame" style="display:none" title="Form submission" aria-hidden="true"></iframe>
</div>

<style>
    .modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.85);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
        backdrop-filter: blur(6px);
    }
    .modal.active { display: flex; }

    .modal-content {
        background: #1a1a1a;
        border-radius: 20px;
        max-width: 480px;
        width: 100%;
        min-height: 400px;
        max-height: 90svh;
        overflow-y: auto;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 40px 100px rgba(0,0,0,0.8);
        display: flex;
        flex-direction: column;
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .modal-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 600;
        color: #e8c27a;
        letter-spacing: 0.02em;
    }

    .modal-desc {
        font-size: 0.85rem;
        color: var(--text-dim);
        line-height: 1.55;
        padding: 12px 20px 0;
    }

    .modal-close {
        background: rgba(255,255,255,0.06);
        border: none;
        color: #a0a0a0;
        font-size: 1.3rem;
        cursor: pointer;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .modal-close:hover { background: rgba(255,255,255,0.12); color: #fff; }

    /* Step indicator */
    .step-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 24px 24px 0;
        flex-shrink: 0;
    }

    .step-dot {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        color: #666;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .step-dot.active {
        background: #e8c27a;
        color: #0f0f0f;
    }

    .step-dot.done {
        background: #e8c27a;
        color: #0f0f0f;
        opacity: 0.6;
    }

    .step-line {
        flex: 1;
        max-width: 48px;
        height: 2px;
        background: rgba(255,255,255,0.1);
        border-radius: 1px;
    }

    /* Form */
    .wizard-form {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 32px 24px 24px;
        min-height: 0;
    }

    .step-content {
        flex: 1;
        position: relative;
    }

    .step-panel {
        display: none;
        flex-direction: column;
        gap: 12px;
        animation: fadeIn 0.25s ease;
    }

    .step-panel.active { display: flex; }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .step-panel { animation: none; }
        .spinner { animation-duration: 1.4s; }
    }

    .step-label {
        font-size: 1.05rem;
        font-weight: 500;
        color: #fff;
        margin-bottom: 4px;
    }

    .input {
        width: 100%;
        padding: 12px 14px;
        background: #262626;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: #fff;
        font-size: 0.95rem;
        font-family: 'DM Sans', sans-serif;
        outline: none;
        transition: border-color 0.2s;
    }

    .input:focus { border-color: #e8c27a; }
    .input::placeholder { color: #555; }

    .error-msg {
        font-size: 0.8rem;
        color: #ff8585;
        min-height: 1.2em;
    }

    /* Mode selector */
    .mode-options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .mode-option {
        flex: 1;
        min-width: 140px;
    }

    .mode-option input { display: none; }

    .mode-option span {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        background: #262626;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        color: #a0a0a0;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .mode-option small {
        display: block;
        font-weight: 400;
        font-size: 0.75rem;
        margin-top: 4px;
        color: #666;
    }

    .mode-option input:checked + span {
        background: rgba(232,194,122,0.12);
        border-color: #e8c27a;
        color: #e8c27a;
    }

    .mode-option input:checked + span small {
        color: rgba(232,194,122,0.7);
    }

    .mode-option input:focus-visible + span {
        outline: 2px solid var(--accent-color);
        outline-offset: 2px;
    }

    .mode-option span:hover {
        border-color: rgba(255,255,255,0.2);
        color: #fff;
    }

    /* File upload */
    .file-upload {
        border: 1px dashed rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        position: relative;
    }

    .file-upload:hover,
    .file-upload.dragover {
        border-color: #e8c27a;
        background: rgba(232,194,122,0.05);
    }

    .file-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: #a0a0a0;
    }

    .file-placeholder svg { margin-bottom: 4px; }
    .file-placeholder small { font-size: 0.75rem; color: #555; }

    .file-preview {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .file-preview img {
        max-height: 180px;
        max-width: 100%;
        border-radius: 8px;
        object-fit: contain;
    }

    .file-remove {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: rgba(0,0,0,0.8);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Style options */
    .style-options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .style-option {
        flex: 1;
        min-width: 100px;
    }

    .style-option input { display: none; }

    .style-option span {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px 16px;
        background: #262626;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        color: #a0a0a0;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }

    .style-option input:checked + span {
        background: rgba(232,194,122,0.12);
        border-color: #e8c27a;
        color: #e8c27a;
    }

    .style-option input:focus-visible + span {
        outline: 2px solid var(--accent-color);
        outline-offset: 2px;
    }

    .style-option span:hover {
        border-color: rgba(255,255,255,0.2);
        color: #fff;
    }

    /* Consent */
    .consent-label {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-top: 12px;
        cursor: pointer;
    }

    .consent-label input[type="checkbox"] {
        margin-top: 3px;
        width: 18px;
        height: 18px;
        accent-color: #e8c27a;
        flex-shrink: 0;
    }

    .consent-label span {
        font-size: 0.85rem;
        color: #a0a0a0;
        line-height: 1.4;
    }

    .consent-label a {
        color: #e8c27a;
        text-decoration: underline;
    }

    /* Navigation */
    .step-nav {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .btn-back {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.12);
        color: #a0a0a0;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        margin-right: auto;
    }

    .btn-back:hover {
        border-color: rgba(255,255,255,0.25);
        color: #fff;
    }

    .btn-next, .btn-submit {
        background: #e8c27a;
        border: none;
        color: #0f0f0f;
        padding: 10px 28px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-next:hover, .btn-submit:hover { background: #d4ae65; }
    .btn-next:disabled, .btn-submit:disabled { opacity: 0.35; cursor: not-allowed; }

    /* Loading */
    #loadingContainer {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        gap: 16px;
        padding: 60px 24px;
    }

    .spinner {
        width: 36px;
        height: 36px;
        border: 3px solid rgba(232,194,122,0.2);
        border-top-color: #e8c27a;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    #loadingContainer p { color: #a0a0a0; font-size: 0.9rem; }

    /* Success */
    #successContainer {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        text-align: center;
        padding: 60px 24px;
    }

    .success-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #e8c27a;
        color: #0f0f0f;
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    #successContainer h2 { font-size: 1.4rem; margin-bottom: 8px; }
    #successContainer p { color: #a0a0a0; margin-bottom: 24px; max-width: 320px; }

    .btn-success-wa {
        display: inline-block;
        background: #25D366;
        color: #fff;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 16px;
        transition: opacity 0.2s;
    }

    .btn-success-wa:hover { opacity: 0.9; }

    .btn-new {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.15);
        color: #a0a0a0;
        padding: 12px 32px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-new:hover { border-color: rgba(255,255,255,0.3); color: #fff; }

    /* Error */
    #errorContainer {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        text-align: center;
        padding: 60px 24px;
    }

    .error-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #ff4444;
        color: #fff;
        font-size: 1.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    #errorContainer h2 { font-size: 1.4rem; margin-bottom: 8px; }
    #errorContainer p { color: #a0a0a0; margin-bottom: 24px; }

    .btn-retry {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff;
        padding: 12px 32px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-retry:hover { border-color: rgba(255,255,255,0.3); }

    @media (max-width: 560px) {
        .modal-content { max-height: 96svh; border-radius: 14px; }
        .wizard-form { padding: 24px 16px 16px; }
        .style-options { flex-direction: column; }
        .style-option { min-width: 0; }
        .mode-options { flex-direction: column; }
        .mode-option { min-width: 0; }
    }
</style>

<style is:global>
    body.modal-open-qualis { overflow: hidden; }
</style>

<script define:vars={{
    SUBMITKIT_URL,
    WHATSAPP_BASE,
    NAME_ERROR: s[0].nameError,
    MODE_ERROR: s[0].modeLabel,
    EMAIL_ERROR: s[1].emailError,
    PHOTO_ERROR_FORMAT: s[2].photoErrorFormat,
    PHOTO_ERROR_SIZE: s[2].photoErrorSize,
    WA_MESSAGE_TEMPLATE: dict.modal.success.waMessage,
}}>
    const MODAL = document.getElementById('qualisModal');
    const FORM = document.getElementById('wizardForm');
    const FORM_WRAPPER = FORM;
    const LOADING = document.getElementById('loadingContainer');
    const SUCCESS = document.getElementById('successContainer');
    const ERROR = document.getElementById('errorContainer');
    const ERROR_MSG = document.getElementById('errorMsg');

    let currentStep = 1;
    const totalSteps = 4;
    let fileData = null;
    let triggerEl = null;

    function getFocusable(el) {
        if (!el) return [];
        return Array.from(el.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
            .filter(n => !n.disabled && n.offsetParent !== null);
    }

    function trapFocus(e) {
        const focusable = getFocusable(MODAL);
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.key === 'Tab') {
            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first.focus();
            }
        }
    }

    const els = (id) => document.getElementById(id);

    const show = (el) => { if (el) el.style.display = 'flex'; };
    const hide = (el) => { if (el) el.style.display = 'none'; };
    const block = (el) => { if (el) el.style.display = ''; };

    function openModal() {
        triggerEl = document.activeElement;
        resetWizard();
        MODAL?.classList.add('active');
        MODAL?.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open-qualis');
        setTimeout(() => {
            const first = getFocusable(MODAL)[0];
            if (first) first.focus();
        }, 50);
        document.addEventListener('keydown', trapFocus);
    }

    function closeModal() {
        MODAL?.classList.remove('active');
        MODAL?.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-open-qualis');
        document.removeEventListener('keydown', trapFocus);
        if (triggerEl) setTimeout(() => triggerEl.focus(), 50);
    }

    function goToStep(step) {
        currentStep = step;
        document.querySelectorAll('.step-panel').forEach(p => p.classList.toggle('active', +p.dataset.step === step));
        document.querySelectorAll('.step-dot').forEach(d => {
            const s = +d.dataset.step;
            d.classList.toggle('active', s === step);
            d.classList.toggle('done', s < step);
            d.setAttribute('aria-valuenow', String(s));
        });

        const back = els('btnBack');
        back.style.visibility = step > 1 ? 'visible' : 'hidden';

        const next = els('btnNext');
        const submit = els('btnSubmit');
        if (step === totalSteps) {
            next.style.display = 'none';
            submit.style.display = '';
            validateStep(step);
        } else {
            next.style.display = '';
            submit.style.display = 'none';
        }

        validateStep(step);
        setTimeout(() => {
            const f = getFocusable(MODAL)[0];
            if (f) f.focus();
        }, 50);
    }

    function validateStep(step) {
        const btn = step === totalSteps ? els('btnSubmit') : els('btnNext');
        btn.disabled = true;

        switch (step) {
            case 1: {
                const v = els('name').value.trim();
                const mode = FORM.querySelector('input[name="Modo"]:checked');
                btn.disabled = v.length < 2 || !mode;
                break;
            }
            case 2: {
                const v = els('email').value.trim();
                btn.disabled = !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
                break;
            }
            case 3: {
                btn.disabled = !fileData;
                break;
            }
            case 4: {
                const style = FORM.querySelector('input[name="Estilo"]:checked');
                const consent = FORM.querySelector('input[name="Consentimiento"]:checked');
                btn.disabled = !style || !consent;
                break;
            }
        }
    }

    function resetWizard() {
        FORM.reset();
        fileData = null;
        els('filePlaceholder').style.display = '';
        els('filePreview').style.display = 'none';
        els('previewImg').src = '';
        document.querySelectorAll('.error-msg').forEach(e => e.textContent = '');
        hide(SUCCESS);
        hide(ERROR);
        block(FORM_WRAPPER);
        hide(LOADING);
        goToStep(1);
    }

    // Event listeners
    els('closeModal')?.addEventListener('click', closeModal);
    els('btnNew')?.addEventListener('click', resetWizard);

    MODAL?.addEventListener('click', (e) => { if (e.target === MODAL) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && MODAL?.classList.contains('active')) closeModal(); });

    window.addEventListener('toggle-modal', () => {
        MODAL?.classList.contains('active') ? closeModal() : openModal();
    });

    // Input validation on change
    els('name')?.addEventListener('input', () => {
        const v = els('name').value.trim();
        els('nameError').textContent = v.length < 2 && v.length > 0 ? NAME_ERROR : '';
        validateStep(1);
    });

    FORM.querySelectorAll('input[name="Modo"]').forEach(r => {
        r.addEventListener('change', () => validateStep(1));
    });

    els('email')?.addEventListener('input', () => {
        const v = els('email').value.trim();
        const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
        els('emailError').textContent = v.length > 0 && !valid ? EMAIL_ERROR : '';
        validateStep(2);
    });

    // File upload
    const fileInput = els('photo');
    const dropZone = els('fileDropZone');

    fileInput?.addEventListener('change', () => {
        handleFile(fileInput.files[0]);
    });

    dropZone?.addEventListener('click', () => fileInput?.click());
    dropZone?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            fileInput?.click();
        }
    });

    dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const f = e.dataTransfer?.files?.[0];
        if (f) {
            fileInput.files = e.dataTransfer.files;
            handleFile(f);
        }
    });

    els('fileRemove')?.addEventListener('click', (e) => {
        e.stopPropagation();
        clearFile();
    });

    function handleFile(f) {
        els('photoError').textContent = '';
        if (!f) { clearFile(); return; }
        if (!['image/png','image/jpeg'].includes(f.type)) {
            els('photoError').textContent = PHOTO_ERROR_FORMAT;
            clearFile();
            return;
        }
        if (f.size > 5 * 1024 * 1024) {
            els('photoError').textContent = PHOTO_ERROR_SIZE;
            clearFile();
            return;
        }
        fileData = f;
        els('filePlaceholder').style.display = 'none';
        els('filePreview').style.display = 'flex';
        const reader = new FileReader();
        reader.onload = (e) => { els('previewImg').src = e.target.result; };
        reader.readAsDataURL(f);
        validateStep(3);
    }

    function clearFile() {
        fileData = null;
        fileInput.value = '';
        els('filePlaceholder').style.display = '';
        els('filePreview').style.display = 'none';
        els('previewImg').src = '';
        validateStep(3);
    }

    // Style + consent validation
    FORM.querySelectorAll('input[name="Estilo"]').forEach(r => {
        r.addEventListener('change', () => validateStep(4));
    });

    FORM.querySelector('input[name="Consentimiento"]')?.addEventListener('change', () => validateStep(4));

    // Navigation buttons
    els('btnNext')?.addEventListener('click', () => {
        if (currentStep < totalSteps) goToStep(currentStep + 1);
    });

    els('btnBack')?.addEventListener('click', () => {
        if (currentStep > 1) goToStep(currentStep - 1);
    });

    // Submit — native POST via hidden iframe
    FORM?.addEventListener('submit', (e) => {
        e.preventDefault();
        if (els('btnSubmit').disabled) return;

        block(LOADING);
        hide(FORM_WRAPPER);
        hide(ERROR);

        FORM.action = SUBMITKIT_URL;
        FORM.method = 'POST';
        FORM.enctype = 'multipart/form-data';
        FORM.target = 'submit-frame';
        FORM.submit();

        const mode = FORM.querySelector('input[name="Modo"]:checked').value;
        const name = els('name').value.trim();
        const msg = WA_MESSAGE_TEMPLATE.replace('{name}', name).replace('{mode}', mode);
        els('successWaLink').href = `${WHATSAPP_BASE}?text=${encodeURIComponent(msg)}`;

        hide(LOADING);
        show(SUCCESS);
    });

    els('btnRetry')?.addEventListener('click', () => {
        hide(ERROR);
        block(FORM_WRAPPER);
    });

    // Init
    goToStep(1);
</script>
