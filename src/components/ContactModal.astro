---
const privacyUrl = `${import.meta.env.BASE_URL}privacidad/`;
---
<div class="modal" id="contactModal" role="dialog" aria-modal="true" aria-labelledby="stepTitle1" aria-hidden="true" tabindex="-1">
    <div class="modal-content" id="modalContent">
        <button class="modal-close" id="closeModal" type="button" aria-label="Cerrar">&times;</button>

        <div class="progress-container" aria-hidden="true">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <div id="formWrapper">
            <form id="contactForm" enctype="multipart/form-data" novalidate>
                <input type="hidden" name="access_key" value="08ec9f6d-e485-4aa6-a4f1-f56823048f86">
                <input type="hidden" name="from_name" value="Zynera Staging Wizard">
                <input type="checkbox" name="botcheck" class="honeypot" tabindex="-1" autocomplete="off">

                <div class="step active" data-step="1">
                    <h2 class="step-title" id="stepTitle1">¿A quién le enviamos la foto?</h2>
                    <p class="step-subtitle">Ingresá tus datos para recibir el resultado procesado.</p>

                    <div class="form-group">
                        <label for="contactName">Nombre Completo</label>
                        <input type="text" name="name" id="contactName" required placeholder="Tu nombre" autocomplete="name">
                    </div>
                    <div class="form-group">
                        <label for="contactEmail">Email Profesional</label>
                        <input type="email" name="email" id="contactEmail" required placeholder="tu@empresa.com" autocomplete="email">
                    </div>
                    <div class="form-group">
                        <label for="contactMessage">Instrucciones</label>
                        <textarea name="message" id="contactMessage" required placeholder="Ej: living vacío, estilo cálido, mantener pisos y ventanas"></textarea>
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn-next">Siguiente →</button>
                    </div>
                </div>

                <div class="step" data-step="2">
                    <h2 class="step-title" id="stepTitle2">Subí tu foto</h2>
                    <p class="step-subtitle">Aceptamos JPG, PNG o WebP hasta 10 MB.</p>

                    <div class="upload-zone" id="dropZone">
                        <input type="file" name="attachment" id="fileInput" accept="image/jpeg,image/png,image/webp" class="file-input" required>
                        <div class="upload-content">
                            <span class="upload-icon" aria-hidden="true">📸</span>
                            <p id="fileStatus">Arrastrá tu foto aquí o hacé clic para buscar</p>
                        </div>
                    </div>

                    <p class="field-error" id="fileError" role="alert" hidden></p>

                    <div id="imagePreview" class="image-preview" hidden>
                        <img src="" alt="Vista previa de la foto seleccionada" id="previewImg">
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn-prev">← Volver</button>
                        <button type="button" class="btn-next">Siguiente →</button>
                    </div>
                </div>

                <div class="step" data-step="3">
                    <h2 class="step-title" id="stepTitle3">Elegí el estilo</h2>
                    <p class="step-subtitle">¿Cómo te gustaría decorar este ambiente?</p>

                    <div class="style-grid">
                        <label class="style-card">
                            <input type="radio" name="style" value="Mediterráneo" checked>
                            <div class="style-info">
                                <strong>Mediterráneo</strong>
                                <span>Cálido y orgánico</span>
                            </div>
                        </label>
                        <label class="style-card">
                            <input type="radio" name="style" value="Manhattan">
                            <div class="style-info">
                                <strong>Manhattan</strong>
                                <span>Industrial y lujoso</span>
                            </div>
                        </label>
                        <label class="style-card">
                            <input type="radio" name="style" value="Minimalista">
                            <div class="style-info">
                                <strong>Minimalista</strong>
                                <span>Puro y funcional</span>
                            </div>
                        </label>
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn-prev">← Volver</button>
                        <button type="button" class="btn-next">Siguiente →</button>
                    </div>
                </div>

                <div class="step" data-step="4">
                    <h2 class="step-title" id="stepTitle4">Confirmá el envío</h2>
                    <p class="step-subtitle">Revisá los datos antes de enviarnos tu foto.</p>

                    <dl class="summary-list">
                        <div>
                            <dt>Nombre</dt>
                            <dd id="summaryName">-</dd>
                        </div>
                        <div>
                            <dt>Email</dt>
                            <dd id="summaryEmail">-</dd>
                        </div>
                        <div>
                            <dt>Foto</dt>
                            <dd id="summaryFile">-</dd>
                        </div>
                        <div>
                            <dt>Estilo</dt>
                            <dd id="summaryStyle">-</dd>
                        </div>
                    </dl>

                    <label class="consent-row">
                        <input type="checkbox" name="consent" id="consentInput" required>
                        <span>Acepto que Zynera use esta foto y mis datos para procesar esta prueba. Leí la <a href={privacyUrl}>política de privacidad</a>.</span>
                    </label>

                    <p class="form-error" id="formError" role="alert" hidden></p>

                    <div class="wizard-actions">
                        <button type="button" class="btn-prev">← Volver</button>
                        <button type="submit" class="btn-submit" id="submitBtn">Finalizar y enviar →</button>
                    </div>
                </div>
            </form>
        </div>

        <div id="successMessage" class="success-message" hidden>
            <div class="success-icon" aria-hidden="true">✨</div>
            <h2>¡Recibido con éxito!</h2>
            <p>Nuestros diseñadores están procesando tu foto.<br/>Te enviaremos el resultado a tu email en menos de 24hs.</p>
            <button class="btn-contact" id="closeSuccess" type="button">Cerrar</button>
        </div>
    </div>
</div>

<style>
    .progress-container {
        width: 100%;
        height: 4px;
        background: rgba(255,255,255,0.05);
        position: absolute;
        top: 0;
        left: 0;
        overflow: hidden;
    }

    .progress-bar {
        height: 100%;
        background: var(--accent-color);
        width: 25%;
        transition: var(--transition-smooth);
    }

    .step {
        display: none;
        animation: fadeIn 0.4s ease forwards;
    }

    .step.active {
        display: block;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .step-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        margin-bottom: 8px;
        padding-right: 36px;
    }

    .step-subtitle {
        color: var(--text-dim);
        font-size: 0.9rem;
        margin-bottom: 32px;
    }

    .upload-zone {
        border: 2px dashed rgba(232, 194, 122, 0.2);
        border-radius: 12px;
        padding: 40px 20px;
        text-align: center;
        position: relative;
        transition: var(--transition-smooth);
        margin-bottom: 12px;
        cursor: pointer;
    }

    .upload-zone:hover, .upload-zone.dragover {
        background: rgba(232, 194, 122, 0.05);
        border-color: var(--accent-color);
    }

    .file-input {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
    }

    .upload-icon {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 16px;
    }

    .image-preview {
        width: 100%;
        max-height: 220px;
        overflow: hidden;
        border-radius: 8px;
        margin: 20px 0 24px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .image-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .style-grid {
        display: grid;
        gap: 12px;
        margin-bottom: 32px;
    }

    .style-card {
        background: #252525;
        border: 1px solid #333;
        padding: 20px;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: var(--transition-smooth);
    }

    .style-card:hover {
        border-color: var(--accent-color);
    }

    .style-card input[type="radio"] {
        accent-color: var(--accent-color);
        width: 20px;
        height: 20px;
        flex: 0 0 auto;
    }

    .style-info strong {
        display: block;
        color: white;
    }

    .style-info span {
        font-size: 0.8rem;
        color: var(--text-dim);
    }

    .style-card:has(input:checked) {
        border-color: var(--accent-color);
        background: rgba(232, 194, 122, 0.05);
    }

    .summary-list {
        display: grid;
        gap: 12px;
        margin-bottom: 24px;
    }

    .summary-list div {
        display: grid;
        grid-template-columns: 110px 1fr;
        gap: 12px;
        padding: 14px;
        background: #252525;
        border: 1px solid #333;
        border-radius: 8px;
    }

    .summary-list dt {
        color: var(--text-dim);
        font-size: 0.85rem;
    }

    .summary-list dd {
        color: var(--text-main);
        overflow-wrap: anywhere;
    }

    .consent-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        color: var(--text-dim);
        font-size: 0.86rem;
        line-height: 1.5;
    }

    .consent-row input {
        margin-top: 4px;
        accent-color: var(--accent-color);
        flex: 0 0 auto;
    }

    .consent-row a {
        color: var(--accent-color);
    }

    .field-error,
    .form-error {
        color: #ffb4a8;
        font-size: 0.86rem;
        margin-top: 8px;
    }

    .wizard-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .btn-prev {
        background: transparent;
        border: 1px solid #444;
        color: var(--text-dim);
        padding: 12px 24px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-next, .btn-submit {
        background: var(--accent-color);
        color: var(--bg-color);
        border: none;
        padding: 12px 32px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        transition: var(--transition-smooth);
    }

    .btn-next:hover, .btn-submit:hover {
        opacity: 0.9;
    }

    .btn-next:disabled,
    .btn-submit:disabled {
        cursor: wait;
        opacity: 0.65;
    }

    .success-message {
        text-align: center;
        padding: 40px 0;
    }

    .success-icon {
        font-size: 4rem;
        margin-bottom: 24px;
    }

    .success-message h2 {
        font-family: 'Playfair Display', serif;
        margin-bottom: 12px;
    }

    .success-message p {
        color: var(--text-dim);
        margin-bottom: 24px;
    }

    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.9);
        z-index: 2000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(8px);
    }

    .modal.active {
        display: flex;
    }

    .modal-content {
        background: var(--card-bg);
        padding: 48px;
        border-radius: 20px;
        max-width: 590px;
        width: 100%;
        max-height: calc(100svh - 40px);
        overflow-y: auto;
        position: relative;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    }

    .modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: none;
        border: none;
        color: var(--text-dim);
        font-size: 2rem;
        cursor: pointer;
        z-index: 10;
        line-height: 1;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.9rem;
        color: var(--text-dim);
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        background: #252525;
        border: 1px solid #333;
        padding: 14px;
        border-radius: 8px;
        color: white;
        font-family: inherit;
        font-size: 1rem;
    }

    .form-group textarea {
        min-height: 110px;
        resize: vertical;
    }

    .btn-contact {
        background: transparent;
        border: 1px solid var(--accent-color);
        color: var(--accent-color);
        padding: 12px 24px;
        border-radius: 50px;
        cursor: pointer;
        font-weight: 500;
    }

    .honeypot {
        position: absolute;
        left: -9999px;
        opacity: 0;
    }

    @media (max-width: 560px) {
        .modal {
            align-items: flex-start;
            padding: 12px;
        }

        .modal-content {
            padding: 40px 22px 28px;
        }

        .summary-list div {
            grid-template-columns: 1fr;
            gap: 4px;
        }

        .wizard-actions {
            flex-direction: column-reverse;
        }

        .btn-prev,
        .btn-next,
        .btn-submit {
            width: 100%;
        }
    }
</style>

<style is:global>
    body.modal-open {
        overflow: hidden;
    }
</style>

<script>
    const TOTAL_STEPS = 4;
    const MAX_FILE_SIZE_BYTES = 10 * 1024 * 1024;
    const ACCEPTED_FILE_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

    const modal = document.getElementById('contactModal');
    const formWrapper = document.getElementById('formWrapper');
    const successMessage = document.getElementById('successMessage');
    const contactForm = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const progressBar = document.getElementById('progressBar');
    const steps = document.querySelectorAll('.step');
    const nextBtns = document.querySelectorAll('.btn-next');
    const prevBtns = document.querySelectorAll('.btn-prev');
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const dropZone = document.getElementById('dropZone');
    const fileStatus = document.getElementById('fileStatus');
    const fileError = document.getElementById('fileError');
    const formError = document.getElementById('formError');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;
    const closeSuccess = document.getElementById('closeSuccess');
    const summaryName = document.getElementById('summaryName');
    const summaryEmail = document.getElementById('summaryEmail');
    const summaryFile = document.getElementById('summaryFile');
    const summaryStyle = document.getElementById('summaryStyle');

    let currentStep = 1;
    let previewUrl = '';
    let lastFocusedElement: Element | null = null;

    const focusableSelector = [
        'a[href]',
        'button:not([disabled])',
        'input:not([disabled]):not([type="hidden"])',
        'textarea:not([disabled])',
        'select:not([disabled])',
        '[tabindex]:not([tabindex="-1"])'
    ].join(',');

    const updateWizard = () => {
        steps.forEach(step => {
            const stepNum = parseInt(step.getAttribute('data-step') || '1');
            step.classList.toggle('active', stepNum === currentStep);
        });

        if (progressBar) {
            progressBar.style.width = `${(currentStep / TOTAL_STEPS) * 100}%`;
        }

        modal?.setAttribute('aria-labelledby', `stepTitle${currentStep}`);

        if (currentStep === 4) {
            updateSummary();
        }
    };

    const focusCurrentStep = () => {
        const activeStep = document.querySelector(`.step[data-step="${currentStep}"]`);
        const firstField = activeStep?.querySelector(focusableSelector) as HTMLElement | null;
        firstField?.focus();
    };

    const setFieldError = (message = '') => {
        if (!fileError) return;
        fileError.textContent = message;
        fileError.hidden = message.length === 0;
    };

    const setFormError = (message = '') => {
        if (!formError) return;
        formError.textContent = message;
        formError.hidden = message.length === 0;
    };

    const revokePreviewUrl = () => {
        if (previewUrl) {
            URL.revokeObjectURL(previewUrl);
            previewUrl = '';
        }
    };

    const clearFileSelection = () => {
        revokePreviewUrl();
        if (fileInput) fileInput.value = '';
        if (previewImg) previewImg.src = '';
        if (imagePreview) imagePreview.hidden = true;
        if (fileStatus) fileStatus.textContent = 'Arrastrá tu foto aquí o hacé clic para buscar';
    };

    const resetFile = () => {
        clearFileSelection();
        fileInput?.setCustomValidity('');
    };

    const validateSelectedFile = (file: File | undefined) => {
        if (!file) {
            const message = 'Seleccioná una foto para continuar.';
            fileInput?.setCustomValidity(message);
            setFieldError(message);
            return false;
        }

        if (!ACCEPTED_FILE_TYPES.includes(file.type)) {
            const message = 'Usá una imagen JPG, PNG o WebP.';
            fileInput?.setCustomValidity(message);
            setFieldError(message);
            return false;
        }

        if (file.size > MAX_FILE_SIZE_BYTES) {
            const message = 'La foto debe pesar 10 MB o menos.';
            fileInput?.setCustomValidity(message);
            setFieldError(message);
            return false;
        }

        fileInput?.setCustomValidity('');
        setFieldError('');
        return true;
    };

    const handleFile = (file: File | undefined) => {
        if (!validateSelectedFile(file)) {
            clearFileSelection();
            return false;
        }

        revokePreviewUrl();
        previewUrl = URL.createObjectURL(file as File);
        if (fileStatus) fileStatus.textContent = `Foto seleccionada: ${(file as File).name}`;
        if (previewImg && imagePreview) {
            previewImg.src = previewUrl;
            imagePreview.hidden = false;
        }
        return true;
    };

    const validateStep = () => {
        setFormError('');
        const currentStepEl = document.querySelector(`.step[data-step="${currentStep}"]`);
        const requiredFields = currentStepEl?.querySelectorAll('input[required], textarea[required]') || [];

        for (const field of requiredFields) {
            const input = field as HTMLInputElement | HTMLTextAreaElement;
            if (input instanceof HTMLInputElement && input.type === 'file') {
                continue;
            }
            if (!input.checkValidity()) {
                input.reportValidity();
                return false;
            }
        }

        if (currentStep === 2) {
            const validFile = validateSelectedFile(fileInput?.files?.[0]);
            if (!validFile) {
                fileInput?.reportValidity();
                return false;
            }
        }

        return true;
    };

    const updateSummary = () => {
        const name = (document.getElementById('contactName') as HTMLInputElement | null)?.value || '-';
        const email = (document.getElementById('contactEmail') as HTMLInputElement | null)?.value || '-';
        const fileName = fileInput?.files?.[0]?.name || '-';
        const style = (contactForm?.querySelector('input[name="style"]:checked') as HTMLInputElement | null)?.value || '-';

        if (summaryName) summaryName.textContent = name;
        if (summaryEmail) summaryEmail.textContent = email;
        if (summaryFile) summaryFile.textContent = fileName;
        if (summaryStyle) summaryStyle.textContent = style;
    };

    const resetWizard = () => {
        currentStep = 1;
        contactForm?.reset();
        resetFile();
        setFieldError('');
        setFormError('');
        if (formWrapper) formWrapper.hidden = false;
        if (successMessage) successMessage.hidden = true;
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Finalizar y enviar →';
        }
        updateWizard();
    };

    const openModal = () => {
        if (!modal) return;
        lastFocusedElement = document.activeElement;
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open');
        updateWizard();
        window.setTimeout(focusCurrentStep, 0);
    };

    const closeModal = () => {
        if (!modal) return;
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modal-open');
        window.setTimeout(resetWizard, 300);
        (lastFocusedElement as HTMLElement | null)?.focus?.();
    };

    nextBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            if (!validateStep()) return;
            if (currentStep < TOTAL_STEPS) {
                currentStep++;
                updateWizard();
                focusCurrentStep();
            }
        });
    });

    prevBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep--;
                updateWizard();
                focusCurrentStep();
            }
        });
    });

    fileInput?.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        handleFile(file);
    });

    dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
    });

    dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
    });

    dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const file = e.dataTransfer?.files[0];
        if (!file || !validateSelectedFile(file)) {
            clearFileSelection();
            return;
        }

        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file);
        fileInput.files = dataTransfer.files;
        handleFile(file);
    });

    window.addEventListener('toggle-modal', () => {
        if (modal?.classList.contains('active')) {
            closeModal();
        } else {
            openModal();
        }
    });

    document.getElementById('closeModal')?.addEventListener('click', closeModal);
    closeSuccess?.addEventListener('click', closeModal);

    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    modal?.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeModal();
            return;
        }

        if (e.key !== 'Tab') return;

        const focusable = Array.from(modal.querySelectorAll(focusableSelector))
            .filter(el => (el as HTMLElement).offsetParent !== null) as HTMLElement[];

        if (focusable.length === 0) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
        }
    });

    contactForm?.addEventListener('submit', function(e) {
        e.preventDefault();

        if (!validateStep()) return;

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Enviando...';
        }

        const formData = new FormData(contactForm);

        fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
        })
        .then(async (response) => {
            if (response.ok) {
                if (formWrapper) formWrapper.hidden = true;
                if (successMessage) successMessage.hidden = false;
                if (progressBar) progressBar.style.width = '100%';
                closeSuccess?.focus();

                window.setTimeout(() => {
                    if (modal?.classList.contains('active')) {
                        closeModal();
                    }
                }, 10000);
                return;
            }

            let message = 'No pudimos enviar la solicitud. Intentá de nuevo.';
            try {
                const json = await response.json();
                if (json?.message) message = json.message;
            } catch {
                // Keep the generic message when the provider returns a non-JSON error.
            }
            setFormError(message);
        })
        .catch(() => {
            setFormError('Algo salió mal. Por favor intentá de nuevo.');
        })
        .finally(() => {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Finalizar y enviar →';
            }
        });
    });
</script>
